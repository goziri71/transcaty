# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Encryption (required when using *_ENC vars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY=

# PostgreSQL (Drizzle + pg-boss)
# Option A: Plain (dev only - never commit)
DATABASE_URL=postgresql://user:password@localhost:5432/transcaty

# Option B: Encrypted (production - encrypt with: npm run encrypt -- "postgresql://...")
# DATABASE_URL_ENC=

# API key for protected routes (X-API-Key or Authorization: Bearer)
# If unset, auth is disabled (dev only)
# API_KEY=
# API_KEY_ENC=  # encrypted with: npm run encrypt -- "your-secret-key"

# Payok (plain or *_ENC)
# PAYOK_MERCHANT_ID=
# PAYOK_MERCHANT_ID_ENC=
# PAYOK_MERCHANT_PRI_KEY=   # RSA private key PEM
# PAYOK_MERCHANT_PRI_KEY_ENC=
# PAYOK_BASE_URL=           # e.g. https://api.payok.xxx
# PAYOK_BASE_URL_ENC=
# PAYOK_PLATFORM_PUB_KEY=   # Payok public key for verifying callbacks
# PAYOK_PLATFORM_PUB_KEY_ENC=
