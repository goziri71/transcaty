{
  "name": "transcaty",
  "version": "0.1.0",
  "description": "B2B payment platform - domestic and cross-border pay-in and pay-out",
  "type": "module",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/src/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "encrypt": "tsx scripts/encrypt.ts",
    "payok:test": "tsx scripts/payok-test.ts",
    "payok:env-check": "tsx scripts/payok-env-check.ts",
    "payok:key-check": "tsx scripts/payok-key-check.ts"
  },
  "keywords": ["payment", "b2b", "pay-in", "pay-out"],
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/compress": "^8.0.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.0",
    "@fastify/rate-limit": "^10.1.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.1.0",
    "fastify-type-provider-zod": "^4.0.0",
    "pg": "^8.13.0",
    "pg-boss": "^10.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.28.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
